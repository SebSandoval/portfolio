---
// ⚠️  FORMSPREE SETUP:
// 1. Ve a https://formspree.io y crea una cuenta gratuita
// 2. Crea un nuevo form y copia tu endpoint (ej: https://formspree.io/f/xpwzabcd)
// 3. Reemplaza el valor de FORMSPREE_ENDPOINT abajo
const FORMSPREE_ENDPOINT = "https://formspree.io/f/xgopplqa";
---

<section
  id="contact"
  class="section-py"
  style="padding-block: clamp(5rem, 12vw, 9rem);"
>
  <div class="wrapper">
    <p class="section-label reveal">
      <span class="lang-es">Contacto</span>
      <span class="lang-en">Contact</span>
    </p>

    <div class="contact-layout">
      <!-- Left: heading + info -->
      <div class="contact-left">
        <h2 class="contact-heading reveal lang-es">¿Hablamos?</h2>
        <h2 class="contact-heading reveal lang-en">Let's talk.</h2>

        <p class="availability reveal">
          <span class="lang-es"
            >Disponible para proyectos freelance y posiciones full-time</span
          >
          <span class="lang-en"
            >Available for freelance projects and full-time positions</span
          >
        </p>

        <a href="mailto:juansesdvsf@gmail.com" class="email-link reveal">
          juansesdvsf@gmail.com
        </a>

        <div class="social-links reveal">
          <a
            href="https://www.linkedin.com/in/juansebsdev"
            target="_blank"
            rel="noopener noreferrer"
            class="social-link"
          >
            LinkedIn
          </a>
          <span class="social-sep">·</span>
          <a
            href="https://github.com/SebSandoval"
            target="_blank"
            rel="noopener noreferrer"
            class="social-link"
          >
            GitHub
          </a>
        </div>
      </div>

      <!-- Right: form -->
      <div class="form-block reveal">
        <form id="contact-form" novalidate>
          <!-- Honeypot: hidden from humans, bots fill it → rejected by Formspree -->
          <input
            type="text"
            name="_gotcha"
            tabindex="-1"
            aria-hidden="true"
            style="display:none"
            autocomplete="off"
          />

          <div class="field-group">
            <label for="cf-name" class="field-label">
              <span class="lang-es">Nombre</span>
              <span class="lang-en">Name</span>
            </label>
            <input
              id="cf-name"
              name="name"
              type="text"
              class="field-input"
              required
              autocomplete="name"
            />
          </div>

          <div class="field-group">
            <label for="cf-email" class="field-label">Email</label>
            <input
              id="cf-email"
              name="email"
              type="email"
              class="field-input"
              required
              autocomplete="email"
            />
          </div>

          <div class="field-group">
            <label for="cf-message" class="field-label">
              <span class="lang-es">Mensaje</span>
              <span class="lang-en">Message</span>
            </label>
            <textarea
              id="cf-message"
              name="message"
              class="field-input field-textarea"
              rows="5"
              required></textarea>
          </div>

          <button type="submit" class="submit-btn" id="submit-btn">
            <span class="submit-text lang-es">Enviar mensaje</span>
            <span class="submit-text lang-en">Send message</span>
            <span class="submit-loading" aria-hidden="true">...</span>
            <svg
              width="16"
              height="16"
              viewBox="0 0 16 16"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              class="submit-arrow"
              aria-hidden="true"
            >
              <path d="M3 8h10M9 4l4 4-4 4"></path>
            </svg>
          </button>

          <!-- Success -->
          <div
            class="form-success"
            id="form-success"
            role="status"
            aria-live="polite"
            hidden
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 18 18"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              aria-hidden="true"
            >
              <circle cx="9" cy="9" r="7"></circle>
              <path
                d="M6 9l2 2 4-4"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
            <span class="lang-es">¡Mensaje enviado! Te responderé pronto.</span>
            <span class="lang-en">Message sent! I'll get back to you soon.</span
            >
          </div>

          <!-- Error -->
          <div class="form-error" id="form-error" role="alert" hidden>
            <span class="lang-es"
              >Algo salió mal. Escríbeme directo al email.</span
            >
            <span class="lang-en">Something went wrong. Email me directly.</span
            >
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ FORMSPREE_ENDPOINT }}>
  const form = document.getElementById("contact-form");
  const btn = document.getElementById("submit-btn");
  const successEl = document.getElementById("form-success");
  const errorEl = document.getElementById("form-error");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    // Honeypot check — bots fill hidden fields, humans don't
    const honeypot = form.querySelector('input[name="_gotcha"]');
    if (honeypot?.value) return;

    // Loading state
    btn?.setAttribute("data-loading", "");

    const data = new FormData(form);

    try {
      const res = await fetch(FORMSPREE_ENDPOINT, {
        method: "POST",
        body: data,
        headers: { Accept: "application/json" },
      });

      if (res.ok) {
        form.reset();
        successEl?.removeAttribute("hidden");
        errorEl?.setAttribute("hidden", "");
      } else {
        throw new Error("Response not ok");
      }
    } catch {
      errorEl?.removeAttribute("hidden");
      successEl?.setAttribute("hidden", "");
    } finally {
      btn?.removeAttribute("data-loading");
    }
  });
</script>

<style>
  .section-label {
    font-family: var(--font-body);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 500;
    margin-bottom: 3rem;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .section-label::after {
    content: "";
    flex: 1;
    max-width: 40px;
    height: 1px;
    background-color: var(--color-accent);
    opacity: 0.5;
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: start;
  }

  @media (min-width: 768px) {
    .contact-layout {
      grid-template-columns: 1fr 1fr;
      gap: 6rem;
    }
  }

  /* Left */
  .contact-left {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-heading {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 6rem);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--color-fg);
  }

  .availability {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--color-muted);
    font-weight: 300;
    line-height: 1.6;
    max-width: 36ch;
  }

  .email-link {
    font-family: var(--font-body);
    font-size: clamp(0.9rem, 1.8vw, 1.1rem);
    font-weight: 500;
    color: var(--color-fg);
    text-decoration: none;
    border-bottom: 1.5px solid transparent;
    padding-bottom: 2px;
    transition:
      color 0.2s,
      border-color 0.2s;
    width: fit-content;
    word-break: break-all;
  }

  .email-link:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  .social-links {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .social-link {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--color-muted);
    text-decoration: none;
    font-weight: 400;
    transition: color 0.2s;
  }

  .social-link:hover {
    color: var(--color-accent);
  }

  .social-sep {
    color: var(--color-accent);
    opacity: 0.4;
    font-size: 0.7rem;
  }

  /* Form */
  .form-block {
    display: flex;
    flex-direction: column;
  }

  form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .field-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .field-label {
    font-family: var(--font-body);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    font-weight: 500;
  }

  .field-input {
    font-family: var(--font-body);
    font-size: 0.92rem;
    color: var(--color-fg);
    background-color: transparent;
    border: none;
    border-bottom: 1px solid rgba(107, 100, 96, 0.3);
    padding: 0.6rem 0;
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
    resize: none;
    -webkit-appearance: none;
  }

  .field-input:focus {
    border-bottom-color: var(--color-accent);
  }

  .field-input::placeholder {
    color: rgba(107, 100, 96, 0.4);
  }

  .field-textarea {
    line-height: 1.6;
    min-height: 120px;
  }

  .submit-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-bg);
    background-color: var(--color-fg);
    border: none;
    padding: 0.85rem 1.75rem;
    cursor: pointer;
    transition:
      background-color 0.2s,
      gap 0.2s;
    width: fit-content;
    position: relative;
  }

  .submit-btn:hover {
    background-color: var(--color-accent);
    gap: 12px;
  }

  .submit-loading {
    display: none;
    letter-spacing: 0.1em;
  }

  .submit-btn[data-loading] .submit-text {
    display: none;
  }
  .submit-btn[data-loading] .submit-arrow {
    display: none;
  }
  .submit-btn[data-loading] .submit-loading {
    display: inline;
  }
  .submit-btn[data-loading] {
    opacity: 0.7;
    cursor: not-allowed;
  }

  .form-success,
  .form-error {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 0.85rem;
    padding: 0.75rem 1rem;
    border-radius: 2px;
    margin-top: 0.5rem;
  }

  .form-success[hidden],
  .form-error[hidden] {
    display: none;
  }

  .form-success {
    background-color: rgba(194, 85, 58, 0.08);
    color: var(--color-accent);
    border: 1px solid rgba(194, 85, 58, 0.2);
  }

  .form-error {
    background-color: rgba(200, 50, 50, 0.07);
    color: #c84040;
    border: 1px solid rgba(200, 50, 50, 0.2);
  }
</style>
