---

---

<section id="ai" class="section-py ai-section">
  <div class="wrapper">
    <p class="section-label reveal">
      <span class="lang-es">IA & Automatización</span>
      <span class="lang-en">AI & Automation</span>
    </p>

    <div class="ai-header">
      <h2 class="ai-title reveal">
        <span class="lang-es">Integro IA<br /><em>en producción.</em></span>
        <span class="lang-en">I ship AI<br /><em>to production.</em></span>
      </h2>
      <p class="ai-sub reveal">
        <span class="lang-es">
          No solo uso herramientas de IA — las integro dentro de productos
          reales. Desde flujos automatizados con Make hasta APIs de modelos de
          lenguaje, proceso archivos, genero contenido y extraigo datos de forma
          escalable.
        </span>
        <span class="lang-en">
          I don't just use AI tools — I integrate them into real products. From
          automated workflows in Make to language model APIs, I process files,
          generate content, and extract data at scale.
        </span>
      </p>
    </div>

    <!-- Model APIs -->
    <div class="models-row reveal">
      <span class="models-label lang-es">Modelos utilizados</span>
      <span class="models-label lang-en">Models used</span>
      <div class="models-list">
        <span class="model-chip">OpenAI GPT-4o</span>
        <span class="model-chip">Claude (Anthropic)</span>
        <span class="model-chip">Gemini</span>
        <span class="model-chip">OpenRouter</span>
      </div>
    </div>

    <!-- Capabilities grid -->
    <div class="capabilities-grid">
      <div class="cap-card reveal">
        <div class="cap-icon" aria-hidden="true">
          <svg
            width="28"
            height="28"
            viewBox="0 0 28 28"
            fill="none"
            stroke="currentColor"
            stroke-width="1.4"
          >
            <path d="M4 20l6-8 4 5 3-4 7 7"></path>
            <rect x="2" y="2" width="24" height="24" rx="2"></rect>
          </svg>
        </div>
        <h3 class="cap-title">
          <span class="lang-es">Automatización con Make</span>
          <span class="lang-en">Make Automation</span>
        </h3>
        <p class="cap-desc">
          <span class="lang-es"
            >Flujos automatizados que conectan APIs, procesan datos y ejecutan
            lógica de negocio sin intervención manual.</span
          >
          <span class="lang-en"
            >Automated workflows connecting APIs, processing data, and executing
            business logic without manual intervention.</span
          >
        </p>
      </div>

      <div class="cap-card reveal">
        <div class="cap-icon" aria-hidden="true">
          <svg
            width="28"
            height="28"
            viewBox="0 0 28 28"
            fill="none"
            stroke="currentColor"
            stroke-width="1.4"
          >
            <path d="M14 4v8M14 4l-4 4M14 4l4 4"></path>
            <rect x="4" y="14" width="8" height="10" rx="1"></rect>
            <rect x="16" y="14" width="8" height="10" rx="1"></rect>
            <path d="M8 14v-2M20 14v-2M8 12h12"></path>
          </svg>
        </div>
        <h3 class="cap-title">
          <span class="lang-es">Procesamiento de archivos</span>
          <span class="lang-en">File processing</span>
        </h3>
        <p class="cap-desc">
          <span class="lang-es"
            >Carga, análisis y extracción de datos desde documentos (PDF, CSV,
            imágenes) usando modelos multimodales.</span
          >
          <span class="lang-en"
            >Upload, analysis, and data extraction from documents (PDF, CSV,
            images) using multimodal models.</span
          >
        </p>
      </div>

      <div class="cap-card reveal">
        <div class="cap-icon" aria-hidden="true">
          <svg
            width="28"
            height="28"
            viewBox="0 0 28 28"
            fill="none"
            stroke="currentColor"
            stroke-width="1.4"
          >
            <circle cx="14" cy="10" r="5"></circle>
            <path d="M6 24c0-4.4 3.6-8 8-8s8 3.6 8 8" stroke-linecap="round"
            ></path>
            <path d="M20 6l2-2M22 10h2M20 14l2 2"></path>
          </svg>
        </div>
        <h3 class="cap-title">
          <span class="lang-es">Generación de contenido</span>
          <span class="lang-en">Content generation</span>
        </h3>
        <p class="cap-desc">
          <span class="lang-es"
            >Pipelines de generación de texto e imágenes integrados en
            aplicaciones web con control de calidad y prompts estructurados.</span
          >
          <span class="lang-en"
            >Text and image generation pipelines integrated into web apps with
            quality control and structured prompts.</span
          >
        </p>
      </div>

      <div class="cap-card reveal">
        <div class="cap-icon" aria-hidden="true">
          <svg
            width="28"
            height="28"
            viewBox="0 0 28 28"
            fill="none"
            stroke="currentColor"
            stroke-width="1.4"
          >
            <path d="M4 8h20M4 14h14M4 20h8" stroke-linecap="round"></path>
            <circle cx="22" cy="20" r="4"></circle>
            <path
              d="M20 20l1.5 1.5L24 18"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </div>
        <h3 class="cap-title">
          <span class="lang-es">Extracción de datos</span>
          <span class="lang-en">Data extraction</span>
        </h3>
        <p class="cap-desc">
          <span class="lang-es"
            >Extracción estructurada de información desde fuentes no
            estructuradas con outputs en JSON listos para consumir.</span
          >
          <span class="lang-en"
            >Structured extraction of information from unstructured sources with
            JSON outputs ready to consume.</span
          >
        </p>
      </div>
    </div>

    <!-- Tools used -->
    <div class="tools-row reveal">
      <span class="tools-label lang-es">Herramientas de desarrollo con IA</span>
      <span class="tools-label lang-en">AI-powered dev tools</span>
      <div class="tools-list">
        <span class="tool-tag">GitHub Copilot</span>
        <span class="tool-tag">Claude Code</span>
        <span class="tool-tag">Cursor</span>
        <span class="tool-tag">Make (Integromat)</span>
      </div>
    </div>
  </div>
</section>

<style>
  .ai-section {
    background-color: var(--color-fg);
    color: var(--color-bg);
    position: relative;
    overflow: hidden;
  }

  /* Subtle grid background */
  .ai-section::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(245, 240, 232, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(245, 240, 232, 0.04) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
  }

  .section-label {
    font-family: var(--font-body);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 500;
    margin-bottom: 3rem;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .section-label::after {
    content: "";
    flex: 1;
    max-width: 40px;
    height: 1px;
    background-color: var(--color-accent);
    opacity: 0.5;
  }

  .ai-header {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 4rem;
  }

  @media (min-width: 768px) {
    .ai-header {
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: end;
      margin-bottom: 5rem;
    }
  }

  .ai-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-bg);
  }

  .ai-title em {
    font-style: italic;
    color: var(--color-accent);
    font-weight: 700;
  }

  .ai-sub {
    font-family: var(--font-body);
    font-size: clamp(0.9rem, 1.4vw, 1.05rem);
    line-height: 1.75;
    color: rgba(245, 240, 232, 0.65);
    font-weight: 300;
    max-width: 48ch;
  }

  /* Models row */
  .models-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    margin-bottom: 3.5rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(245, 240, 232, 0.1);
  }

  .models-label {
    font-family: var(--font-body);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(245, 240, 232, 0.45);
    font-weight: 500;
    white-space: nowrap;
  }

  .models-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .model-chip {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-bg);
    border: 1px solid rgba(245, 240, 232, 0.2);
    padding: 4px 12px;
    border-radius: 2px;
    letter-spacing: 0.02em;
    transition:
      border-color 0.2s,
      color 0.2s;
  }

  .model-chip:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* Capabilities grid */
  .capabilities-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5px;
    margin-bottom: 3.5rem;
    background-color: rgba(245, 240, 232, 0.08);
  }

  @media (min-width: 640px) {
    .capabilities-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .capabilities-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .cap-card {
    background-color: var(--color-fg);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: background-color 0.25s;
  }

  .cap-card:hover {
    background-color: #222222;
  }

  .cap-icon {
    color: var(--color-accent);
    width: 28px;
    height: 28px;
  }

  .cap-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-bg);
    line-height: 1.2;
  }

  .cap-desc {
    font-family: var(--font-body);
    font-size: 0.85rem;
    line-height: 1.65;
    color: rgba(245, 240, 232, 0.55);
    font-weight: 300;
    flex: 1;
  }

  /* Dev tools */
  .tools-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    padding-top: 2.5rem;
    border-top: 1px solid rgba(245, 240, 232, 0.1);
  }

  .tools-label {
    font-family: var(--font-body);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(245, 240, 232, 0.45);
    font-weight: 500;
  }

  .tools-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tool-tag {
    font-family: var(--font-body);
    font-size: 0.82rem;
    color: rgba(245, 240, 232, 0.7);
    padding: 3px 10px;
    border: 1px solid rgba(245, 240, 232, 0.15);
    border-radius: 2px;
    transition:
      color 0.2s,
      border-color 0.2s;
  }

  .tool-tag:hover {
    color: var(--color-bg);
    border-color: rgba(245, 240, 232, 0.4);
  }
</style>
