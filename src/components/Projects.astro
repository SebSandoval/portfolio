<style>
  .section-label {
    font-family: var(--font-body);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 500;
    margin-bottom: 3rem;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .section-label::after {
    content: "";
    flex: 1;
    max-width: 40px;
    height: 1px;
    background-color: var(--color-accent);
    opacity: 0.5;
  }

  .projects-expander {
    overflow: hidden;
    transition: max-height 0.65s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    padding-bottom: 4px;
  }

  @media (min-width: 640px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .projects-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .project-card {
    background-color: var(--color-bg);
    border: 1px solid rgba(107, 100, 96, 0.15);
    border-radius: 3px;
    overflow: hidden;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
    position: relative;
  }

  .project-card::after {
    content: "";
    position: absolute;
    inset: 0;
    background-color: var(--color-accent);
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .project-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 40px rgba(26, 26, 26, 0.1);
  }

  .project-card:hover::after {
    opacity: 0.04;
  }

  .project-card--github {
    border-color: rgba(194, 85, 58, 0.25);
  }

  .project-inner {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    height: 100%;
  }

  .project-link {
    text-decoration: none;
    color: inherit;
  }

  .project-type {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 400;
  }

  .project-title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-fg);
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .project-desc {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--color-muted);
    line-height: 1.65;
    font-weight: 300;
    flex: 1;
  }

  .project-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .project-stack span {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--color-muted);
    background-color: var(--color-surface);
    padding: 2px 8px;
    border-radius: 2px;
    letter-spacing: 0.04em;
  }

  .project-cta-arrow {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 0.82rem;
    color: var(--color-accent);
    font-weight: 500;
    margin-top: auto;
    transition: gap 0.2s;
  }

  .project-card--github:hover .project-cta-arrow {
    gap: 10px;
  }

  /* Toggle */
  .projects-toggle-wrap {
    display: flex;
    justify-content: center;
    margin-top: 2.5rem;
  }

  .projects-toggle {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: none;
    border: 1px solid rgba(107, 100, 96, 0.2);
    border-radius: 2px;
    padding: 0.6rem 1.4rem;
    cursor: pointer;
    color: var(--color-muted);
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 400;
    letter-spacing: 0.03em;
    transition:
      color 0.2s ease,
      border-color 0.2s ease,
      background-color 0.2s ease;
  }

  .projects-toggle:hover {
    color: var(--color-fg);
    border-color: rgba(107, 100, 96, 0.4);
    background-color: rgba(107, 100, 96, 0.05);
  }

  .toggle-arrow {
    flex-shrink: 0;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .projects-toggle[aria-expanded="true"] .toggle-arrow {
    transform: rotate(180deg);
  }
</style>

<script>
  (function () {
    const esExpander = document.querySelector<HTMLElement>('.projects-expander.lang-es');
    const enExpander = document.querySelector<HTMLElement>('.projects-expander.lang-en');
    const toggle = document.querySelector<HTMLButtonElement>('.projects-toggle');

    if (!esExpander || !enExpander || !toggle) return;

    const es = esExpander!;
    const en = enExpander!;
    const btn = toggle!;

    let expanded = false;
    let clampHeight = 0;

    function getVisibleExpander(): HTMLElement {
      return document.documentElement.classList.contains('lang-en') ? en : es;
    }

    function measure() {
      const expander = getVisibleExpander();
      const grid = expander.querySelector<HTMLElement>('.projects-grid');
      if (!grid) return;

      // Temporarily unlatch to measure real layout
      expander.style.transition = 'none';
      expander.style.maxHeight = 'none';
      // Force reflow
      expander.offsetHeight;

      const cards = Array.from(grid.querySelectorAll<HTMLElement>('.project-card'));
      const gridRect = grid.getBoundingClientRect();

      // Group cards by their top offset (= row grouping)
      const rowMap = new Map<number, HTMLElement[]>();
      cards.forEach((card) => {
        const top = Math.round(card.getBoundingClientRect().top - gridRect.top);
        if (!rowMap.has(top)) rowMap.set(top, []);
        rowMap.get(top)!.push(card);
      });

      const rows = [...rowMap.entries()].sort((a, b) => a[0] - b[0]);

      if (rows.length <= 2) {
        // Fits in 2 rows — hide toggle
        btn.style.display = 'none';
        expander.style.transition = '';
        expander.style.maxHeight = '';
        es.style.maxHeight = '';
        en.style.maxHeight = '';
        return;
      }

      btn.style.display = '';

      // Clamp = bottom edge of the last card in row 2
      const row2Cards = rows[1][1];
      const row2Bottom = Math.max(
        ...row2Cards.map((c) => Math.round(c.getBoundingClientRect().bottom - gridRect.top))
      );
      clampHeight = row2Bottom;

      // Re-enable transition
      expander.style.transition = '';

      if (!expanded) {
        // Apply instantly (no animation on initial set)
        es.style.transition = 'none';
        en.style.transition = 'none';
        es.style.maxHeight = clampHeight + 'px';
        en.style.maxHeight = clampHeight + 'px';
        // Force reflow then restore transitions
        es.offsetHeight;
        en.offsetHeight;
        es.style.transition = '';
        en.style.transition = '';
      } else {
        // Already expanded — keep expanded
        es.style.maxHeight = '9999px';
        en.style.maxHeight = '9999px';
      }
    }

    btn.addEventListener('click', () => {
      expanded = !expanded;
      btn.setAttribute('aria-expanded', String(expanded));

      if (expanded) {
        es.style.maxHeight = es.scrollHeight + 'px';
        en.style.maxHeight = en.scrollHeight + 'px';
        // After transition, unlock height so content can reflow freely
        es.addEventListener(
          'transitionend',
          () => { if (expanded) es.style.maxHeight = '9999px'; },
          { once: true }
        );
      } else {
        // Snap from 9999px to exact scrollHeight first (no animation), then animate to clamp
        es.style.transition = 'none';
        en.style.transition = 'none';
        es.style.maxHeight = es.scrollHeight + 'px';
        en.style.maxHeight = en.scrollHeight + 'px';
        es.offsetHeight;
        en.offsetHeight;
        es.style.transition = '';
        en.style.transition = '';
        es.style.maxHeight = clampHeight + 'px';
        en.style.maxHeight = clampHeight + 'px';
      }
    });

    // Debounced resize handler
    let resizeTimer: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(measure, 120);
    });

    // Re-measure when language switches (class on <html> changes)
    new MutationObserver(() => {
      if (!expanded) measure();
    }).observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

    // Initial measure after first paint
    requestAnimationFrame(() => requestAnimationFrame(measure));
  })();
</script>
